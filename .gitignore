# Dependency directories
node_modules/
/node_modules/
/client/node_modules/
/backend/node_modules/

# Build outputs
/client/dist/
/client/build/
dist/
build/
out/

# Local env files (highly sensitive, must be ignored)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local
*.env.*

# Backend uploads (user uploads should not be committed)
/backend/uploads/*
!/backend/uploads/.gitkeep

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs and databases
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
*.sqlite
